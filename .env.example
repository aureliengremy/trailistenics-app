# ---------------------------------------------------------------------------
# Gabarit des variables d'environnement — COPIER vers backend/.env et frontend/.env
# Ne JAMAIS committer de vraie valeur secrète. Ce fichier ne contient que des exemples.
# ---------------------------------------------------------------------------

# === Backend (backend/.env) ===

# Connexion à la base. Pilote tout : local Postgres aujourd'hui, Neon plus tard.
# Local (Docker Compose fourni) :
DATABASE_URL=postgresql+psycopg://traildev:traildev@localhost:5432/plantrail
# Neon (plus tard) — remplacer simplement par l'URL fournie par Neon, ex :
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@ep-xxx.eu-central-1.aws.neon.tech/plantrail?sslmode=require

# Origines autorisées par CORS (séparées par des virgules) — l'URL du front en dev :
CORS_ORIGINS=http://localhost:5173

# (L'authentification est gérée par Neon Auth côté frontend — aucun secret d'auth backend.)

# (Optionnel) Clé API Resend → emails de notification à l'admin à chaque inscription.
# Absente = pas d'envoi (l'admin consulte l'onglet Admin). Compte Resend avec l'email admin.
# RESEND_API_KEY=re_xxxxxxxx

# === Frontend (frontend/.env) ===

# URL de base de l'API consommée par le client React :
VITE_API_URL=http://localhost:8000

# Neon Auth (Better Auth) — base_url affichée dans Neon Console > Auth (publiable, pas un secret) :
VITE_NEON_AUTH_URL=https://ep-xxx.neonauth.<region>.aws.neon.tech/<db>/auth
